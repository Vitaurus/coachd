# Copy to .env and fill in. NEVER commit .env.

# Where Garmin OAuth tokens are stored inside the container (mounted volume).
# Leave as-is unless you change the volume mount in docker-compose.yml.
GARMINTOKENS=/data/garmin

# Your timezone — required for correct morning/evening report timing.
# Examples: Europe/Kyiv, America/New_York, Asia/Tokyo
TZ=Europe/Kyiv

# --- Added in later steps (NOT needed for `login` / `token-status`) ---
# TG_BOT_TOKEN=
# TG_CHAT_ID=
# ANTHROPIC_API_KEY=
