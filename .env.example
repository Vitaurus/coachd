# Copy to .env and fill in. NEVER commit .env.
#
# `login` / `token-status` need only GARMINTOKENS + TZ.
# `serve` (the coach) needs everything below.

# --- Garmin token store (mounted volume) — leave as-is ---
GARMINTOKENS=/data/garmin

# --- Required by serve ---
# Telegram bot token from @BotFather
TG_BOT_TOKEN=
# Your Telegram chat id(s); comma-separated for a household (e.g. 111,222).
# Don't know it? Message the bot, then run: docker compose run --rm coachd chat-id
TG_CHAT_ID=
# Anthropic auth — provide exactly ONE of the two:
#  (a) a pay-as-you-go API key from console.anthropic.com (sk-ant-api…):
ANTHROPIC_API_KEY=
#  (b) OR a Claude Pro/Max subscription token from `claude setup-token`
#      (sk-ant-oat…) — put it here, leave ANTHROPIC_API_KEY empty.
#      (An OAuth token in ANTHROPIC_API_KEY is rejected by the API with 401.)
# CLAUDE_CODE_OAUTH_TOKEN=
# Your name (used in the coach's prompts)
USER_NAME=
# First day you wore the watch (ISO date), e.g. 2026-06-08
WORN_START=
# Your timezone — REQUIRED for correct report timing and recovery math
TZ=Europe/Kyiv

# --- Optional ---
# Coach language: en (default) or uk. Sets the language the coach SPEAKS and the
# bot's chrome. The prompt corpus is English internally; this only changes output.
# NOTE: the default is `en`. If you ran an earlier Ukrainian build, set COACH_LANG=uk
# here or the coach will switch to English on the next restart.
# COACH_LANG=uk
# Report times in your TZ (24h HH:MM). Defaults: 07:00 / 22:00
# MORNING_TIME=07:00
# EVENING_TIME=22:00
# Coaching model. Default is a balanced daily model; set for max quality:
# MODEL=claude-opus-4-8
# Enable the 1M-context beta:
# USE_1M_CONTEXT=true

# --- Voice notes (local STT, OPT-IN) ---
# Voice transcription is OFF by default to keep the image lean (~1.16GB): the
# faster-whisper stack adds ~320MB, so it's only installed when you opt in.
# To enable voice, set VOICE=true here and REBUILD (it's a build-arg, not just a
# runtime toggle):  docker compose build && docker compose up -d
# VOICE=true turns on BOTH the build (installs faster-whisper) and the runtime
# default. Audio is transcribed on-box — nothing leaves the host. The model
# downloads once at first boot to /data/whisper (persisted), so the first voice
# note after a fresh start may lag while it fetches.
# VOICE=true
#
# The knobs below take effect only on a voice image (VOICE=true):
# Whisper model size. Default `small` is the fail-safe (runs on small boxes). For
# noticeably better Ukrainian/accented accuracy use `medium` (~1.5GB RAM, slower):
# WHISPER_MODEL=medium
# Compute type (quantization). Default `int8` is the lean CPU choice; `int8_float32`
# or `float32` trade RAM/CPU for a little accuracy:
# WHISPER_COMPUTE=int8
# Reject voice notes longer than this many seconds (default 300 = 5 min):
# MAX_VOICE_SECONDS=300
# Where the model is cached (mounted volume → downloaded once, survives restarts):
# STT_DOWNLOAD_ROOT=/data/whisper
# Run a voice-capable image with voice OFF without rebuilding (overrides the
# baked default): VOICE_ENABLED=false
